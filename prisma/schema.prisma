generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id @default(cuid())
  name               String
  email              String              @unique
  passwordHash       String?
  createdAt          DateTime            @default(now())
  brandProfile       BrandProfile?
  subscription       PlanSubscription?
  clientAssets       ClientAsset[]
  serviceAssets      ServiceAsset[]
  testimonialAssets  TestimonialAsset[]
  proposalAssets     ProposalAsset[]
  proposalTemplates  ProposalTemplateAsset[]
  portfolioAssets    PortfolioAsset[]
  marketingArtAssets MarketingArtAsset[]
  artCreditPurchases  ArtCreditPurchase[]
  pushSubscriptions   PushSubscription[]
  accessEvents        AccessEvent[]
}

model PlanSubscription {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  plan                   PlanCode @default(start)
  status                 String   @default("active")
  provider               String?
  providerCustomerId     String?
  providerSubscriptionId String?
  providerCheckoutId     String?
  artCreditBalance       Int      @default(0)
  startedAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SignupPayment {
  id                 String   @id @default(cuid())
  plan               PlanCode
  email              String?
  status             String   @default("pending")
  provider           String   @default("mercadopago")
  providerCheckoutId String?  @unique
  paidAt             DateTime?
  claimedAt          DateTime?
  userId             String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model BrandProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  businessName   String
  logoUrl        String?
  primaryColor   String   @default("#106b5b")
  secondaryColor String   @default("#0F172A")
  accentColor    String   @default("#2563EB")
  whatsapp       String?
  instagram      String?
  email          String?
  website        String?
  bio            String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PortfolioAsset {
  id        String   @id @default(cuid())
  userId    String?
  title     String
  category  String?
  imageUrl  String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ClientAsset {
  id              String   @id @default(cuid())
  userId          String
  name            String
  email           String?
  phone           String?
  segment         String?
  interestService String?
  status          String   @default("lead")
  notes           String?
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ServiceAsset {
  id        String   @id @default(cuid())
  userId    String
  name      String
  price     Int      @default(0)
  deadline  String?
  includes  String[] @default([])
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TestimonialAsset {
  id         String   @id @default(cuid())
  userId     String
  authorName String
  company    String?
  quote      String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProposalAsset {
  id                    String         @id @default(cuid())
  userId                String
  clientName            String
  serviceName           String
  price                 Int            @default(0)
  deadline              String
  validUntil            String?
  payment               String?
  included              String[]       @default([])
  clientEmail           String?
  notes                 String?
  status                ProposalStatus @default(sent)
  publicSlug            String         @unique
  viewCount             Int            @default(0)
  whatsappClickCount    Int            @default(0)
  paymentStatus         String         @default("not_started")
  paymentProvider       String?
  providerCheckoutId    String?
  providerCheckoutUrl   String?
  providerReceiptUrl    String?
  abacatePayProductId   String?
  abacatePayCheckoutId  String?
  abacatePayCheckoutUrl String?
  abacatePayReceiptUrl  String?
  paymentMethod         String?
  paymentPaidAt         DateTime?
  paymentUpdatedAt      DateTime?
  acceptedBy            String?
  acceptedEmail         String?
  acceptedAt            DateTime?
  declinedReason        String?
  declinedAt            DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  user                  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProposalTemplateAsset {
  id            String   @id @default(cuid())
  userId        String
  niche         String
  title         String
  serviceName   String
  price         Int      @default(0)
  deadline      String
  payment       String   @default("")
  included      String[] @default([])
  notes         String   @default("")
  sourceFileUrl String?
  sourceFileName String?
  sourceFileType String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MarketingArtAsset {
  id                String   @id @default(cuid())
  userId            String
  title             String
  format            String
  objective         String
  serviceName       String?
  audience          String?
  callToAction      String?
  caption           String?
  whatsappMessage   String?
  category          String?
  prompt            String
  imageUrl          String
  referenceImageUrl String?
  source            String   @default("fallback")
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ArtCreditPurchase {
  id                 String   @id @default(cuid())
  userId             String
  pack               String
  credits            Int
  status             String   @default("pending")
  provider           String?
  providerCheckoutId String?  @unique
  paidAt             DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh     String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model InterestLead {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  whatsapp     String?
  businessType String?
  mainNeed     String?
  message      String?
  source       String   @default("interest_page")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AccessEvent {
  id        String   @id @default(cuid())
  userId    String?
  path      String
  referrer  String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([userId, createdAt])
}

enum ProposalStatus {
  draft
  sent
  viewed
  awaiting_response
  accepted
  declined
  expired
}

enum PlanCode {
  start
  pro
  plus
  premium
  premium_site
}
