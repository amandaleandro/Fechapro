generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String              @id @default(cuid())
  name               String
  email              String              @unique
  niche              String?
  segment            String?
  passwordHash       String?
  createdAt          DateTime            @default(now())
  brandProfile       BrandProfile?
  subscription       PlanSubscription?
  clientAssets       ClientAsset[]
  serviceAssets      ServiceAsset[]
  testimonialAssets  TestimonialAsset[]
  proposalAssets     ProposalAsset[]
  satisfactionSurveys SatisfactionSurvey[]
  proposalTemplates  ProposalTemplateAsset[]
  portfolioAssets    PortfolioAsset[]
  marketingArtAssets MarketingArtAsset[]
  artCreditPurchases  ArtCreditPurchase[]
  pushSubscriptions   PushSubscription[]
  accessEvents        AccessEvent[]
  supportThreads      SupportThread[]
  supportMessages     SupportMessage[]
}

model PlanSubscription {
  id                     String   @id @default(cuid())
  userId                 String   @unique
  plan                   PlanCode @default(start)
  status                 String   @default("active")
  provider               String?
  providerCustomerId     String?
  providerSubscriptionId String?
  providerCheckoutId     String?
  artCreditBalance       Int      @default(0)
  startedAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SignupPayment {
  id                 String   @id @default(cuid())
  plan               PlanCode
  email              String?
  status             String   @default("pending")
  provider           String   @default("mercadopago")
  providerCheckoutId String?  @unique
  paidAt             DateTime?
  claimedAt          DateTime?
  userId             String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model BrandProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  businessName   String
  logoUrl        String?
  primaryColor   String   @default("#106b5b")
  secondaryColor String   @default("#0F172A")
  accentColor    String   @default("#2563EB")
  whatsapp       String?
  pixKey         String?
  instagram      String?
  email          String?
  website        String?
  bio            String?
  proposalStyle  String   @default("executive")
  proposalIntro  String?
  proposalClosing String?
  proposalTerms  String?
  proposalFaq    String?
  showPortfolio    Boolean  @default(true)
  showTestimonials Boolean  @default(true)
  showServices     Boolean  @default(true)
  showFaq          Boolean  @default(true)
  followUpEnabled  Boolean  @default(false)
  followUpDays     Int      @default(3)
  createdAt        DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PortfolioAsset {
  id        String   @id @default(cuid())
  userId    String?
  title     String
  category  String?
  imageUrl  String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ClientAsset {
  id              String   @id @default(cuid())
  userId          String
  name            String
  email           String?
  phone           String?
  segment         String?
  interestService String?
  status          String   @default("lead")
  notes           String?
  createdAt       DateTime @default(now())
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ServiceAsset {
  id        String   @id @default(cuid())
  userId    String
  name      String
  price     Int      @default(0)
  deadline  String?
  includes  String[] @default([])
  imageUrl  String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TestimonialAsset {
  id         String   @id @default(cuid())
  userId     String
  authorName String
  company    String?
  quote      String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProposalAsset {
  id                    String         @id @default(cuid())
  userId                String
  clientName            String
  serviceName           String
  price                 Int            @default(0)
  deadline              String
  validUntil            String?
  payment               String?
  documentType          String         @default("auto")
  segment               String         @default("auto")
  included              String[]       @default([])
  clientEmail           String?
  clientPhone           String?
  notes                 String?
  status                ProposalStatus @default(sent)
  publicSlug            String         @unique
  viewCount             Int            @default(0)
  whatsappClickCount    Int            @default(0)
  paymentStatus         String         @default("not_started")
  checkoutMode          String         @default("mercadopago")
  paymentProvider       String?
  providerCheckoutId    String?
  providerCheckoutUrl   String?
  providerReceiptUrl    String?
  abacatePayProductId   String?
  abacatePayCheckoutId  String?
  abacatePayCheckoutUrl String?
  abacatePayReceiptUrl  String?
  paymentMethod         String?
  paymentPaidAt         DateTime?
  paymentUpdatedAt      DateTime?
  acceptedBy            String?
  acceptedEmail         String?
  acceptedDocument      String?
  acceptedPhone         String?
  acceptedAt            DateTime?
  acceptedIp            String?
  acceptedUserAgent     String?
  acceptedSnapshotHash  String?
  acceptedContractVersion String?
  declinedReason        String?
  declinedAt            DateTime?
  followUpSentAt        DateTime?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  user                  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  satisfactionSurvey    SatisfactionSurvey?
}

model SatisfactionSurvey {
  id             String        @id @default(cuid())
  proposalId     String        @unique
  userId         String
  testimonialId  String?
  rating         Int?
  recommendScore Int?
  comment        String?
  testimonialOk  Boolean       @default(false)
  clientName     String?
  clientEmail    String?
  serviceCompletedAt DateTime?
  sentAt         DateTime?
  respondedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  proposal       ProposalAsset @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, respondedAt])
  @@index([sentAt])
}

model ProposalTemplateAsset {
  id            String   @id @default(cuid())
  userId        String
  niche         String
  title         String
  serviceName   String
  price         Int      @default(0)
  deadline      String
  payment       String   @default("")
  included      String[] @default([])
  notes         String   @default("")
  sourceFileUrl String?
  sourceFileName String?
  sourceFileType String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MarketingArtAsset {
  id                String   @id @default(cuid())
  userId            String
  title             String
  format            String
  objective         String
  serviceName       String?
  audience          String?
  callToAction      String?
  caption           String?
  whatsappMessage   String?
  category          String?
  prompt            String
  imageUrl          String
  referenceImageUrl String?
  source            String   @default("fallback")
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ArtCreditPurchase {
  id                 String   @id @default(cuid())
  userId             String
  pack               String
  credits            Int
  status             String   @default("pending")
  provider           String?
  providerCheckoutId String?  @unique
  paidAt             DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh     String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model InterestLead {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  whatsapp     String?
  businessType String?
  mainNeed     String?
  message      String?
  source       String   @default("interest_page")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AccessEvent {
  id        String   @id @default(cuid())
  userId    String?
  path      String
  referrer  String?
  userAgent String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([userId, createdAt])
}

model SupportThread {
  id        String           @id @default(cuid())
  userId    String
  subject   String           @default("Suporte")
  status    String           @default("open")
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  SupportMessage[]

  @@index([userId, updatedAt])
  @@index([status, updatedAt])
}

model SupportMessage {
  id        String        @id @default(cuid())
  threadId  String
  userId    String
  role      String
  body      String
  createdAt DateTime      @default(now())
  thread    SupportThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
}

enum ProposalStatus {
  draft
  sent
  viewed
  awaiting_response
  accepted
  declined
  expired
}

enum PlanCode {
  free
  start
  essential
  professional
  complete
  pro
  plus
  premium
  premium_site
  founder_start
  founder_essential
  founder_professional
  founder_complete_site
  founder
}
