# Email via SMTP KingHost
# Se o app estiver fora da infraestrutura KingHost e o envio falhar, habilite SMTP internacional no painel e use smtpi.kinghost.net.
SMTP_HOST="smtp.kinghost.net"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="seu-email@seudominio.com.br"
SMTP_PASSWORD=""
EMAIL_FROM="FechaPro <seu-email@seudominio.com.br>"

# Email via Resend (opcional, fallback caso SMTP_HOST nao esteja configurado)
RESEND_API_KEY=""

# URL publica da aplicacao (usada nos links de email)
APP_URL="https://seudominio.com"

# Web Push (gere com: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:suporte@seudominio.com.br"

# Sentry - monitoramento de erros (https://sentry.io)
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"
NEXT_PUBLIC_SENTRY_ENVIRONMENT="development"

# Healthcheck - obrigatorio em producao. /api/health exige Bearer token ou x-healthcheck-token.
HEALTHCHECK_TOKEN=""

# Storage S3/Cloudflare R2 (opcional - sem isso usa armazenamento local)
S3_BUCKET=""
S3_REGION="auto"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_ENDPOINT="https://<account_id>.r2.cloudflarestorage.com"
S3_PUBLIC_URL="https://pub-<hash>.r2.dev"

# Cloudflare Turnstile - protecao anti-bot (obrigatorio em producao)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Suporte via WhatsApp (somente numeros, com DDD, sem +55, ex: 11999998888)
NEXT_PUBLIC_WHATSAPP_NUMBER=""
# Mensagem inicial enviada ao abrir o suporte (opcional)
NEXT_PUBLIC_WHATSAPP_SUPPORT_MESSAGE="Olá! Preciso de ajuda com o FechaPro."

# Cron de follow-ups - OBRIGATORIO em producao (gere com: openssl rand -hex 32)
# A rota /api/cron/follow-ups falha fechado: sem este valor ela responde 401.
# O crontab do VPS deve enviar o mesmo valor: -H "Authorization: Bearer $CRON_SECRET"
CRON_SECRET=""
