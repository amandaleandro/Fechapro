DATABASE_URL="postgresql://fechapro:fechapro_dev_password@localhost:5436/fechapro?schema=public"
AUTH_SECRET="troque_por_um_valor_aleatorio_forte_em_producao"
ADMIN_EMAILS="admin@fechapro.local"
ADMIN_EMAIL="admin@fechapro.local"
ADMIN_PASSWORD="FechaProAdmin123!"
ADMIN_NAME="Administrador Geral"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.4-mini"
OPENAI_TEXT_MODEL="gpt-5.4-mini"
OPENAI_IMAGE_MODEL="gpt-image-1.5"

# Asaas - pagamentos (https://asaas.com)
# IMPORTANTE: use aspas simples na chave pois ela comeca com $ (evita expansao de variavel)
ASAAS_API_KEY='$aact_prod_sua_chave_aqui'
ASAAS_WEBHOOK_TOKEN="seu_token_secreto_do_webhook"
# Use "true" para ambiente de testes (sandbox.asaas.com), "false" para producao (api.asaas.com)
ASAAS_SANDBOX="false"

POSTGRES_DB="fechapro"
POSTGRES_USER="fechapro"
POSTGRES_PASSWORD="fechapro_dev_password"
UPLOAD_DIR="/app/uploads"

# Email (Resend - https://resend.com)
RESEND_API_KEY=""
EMAIL_FROM="FechaPro <noreply@seudominio.com>"

# URL publica da aplicacao (usada nos links de email)
APP_URL="https://seudominio.com"

# Sentry - monitoramento de erros (https://sentry.io)
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ENVIRONMENT="development"
NEXT_PUBLIC_SENTRY_ENVIRONMENT="development"

# Healthcheck - opcional. Se preencher, /api/health exige Bearer token ou x-healthcheck-token.
HEALTHCHECK_TOKEN=""

# Storage S3/Cloudflare R2 (opcional - sem isso usa armazenamento local)
S3_BUCKET=""
S3_REGION="auto"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_ENDPOINT="https://<account_id>.r2.cloudflarestorage.com"
S3_PUBLIC_URL="https://pub-<hash>.r2.dev"

# Cloudflare Turnstile - protecao anti-bot (https://dash.cloudflare.com)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Suporte via WhatsApp (somente numeros, com DDD, sem +55, ex: 11999998888)
NEXT_PUBLIC_WHATSAPP_NUMBER=""
# Mensagem inicial enviada ao abrir o suporte (opcional)
NEXT_PUBLIC_WHATSAPP_SUPPORT_MESSAGE="Olá! Preciso de ajuda com o FechaPro."
